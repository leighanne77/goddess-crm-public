# Lynda CRM — environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Hard gate: false = dummy data only, true = real data allowed (Phase 2+)
ENTERPRISE_MODE=false

# Database — local Docker Postgres for dev
DATABASE_URL=postgresql+psycopg://lynda:lynda_dev_only@localhost:5432/lynda

# Anthropic API (used in Phase 1 with dummy data only)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (from Day 0 console setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# JWT signing
JWT_SECRET=change-me-to-a-long-random-string

# Access control — comma-separated list of allowed emails
ALLOWED_EMAILS=pat@example.com

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Token encryption key (Fernet). Encrypts Google OAuth tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when ENTERPRISE_MODE=true. In dev, leave blank to disable
# encryption (plaintext fallback for local-only).
TOKEN_ENCRYPTION_KEY=
